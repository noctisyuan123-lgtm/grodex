{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grodex",
  "version": "0.1.0",
  "identifier": "app.grodex.desktop",
  "build": {
    "beforeDevCommand": "cd .. && npm run dev:web",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "cd .. && npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "grodex",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
